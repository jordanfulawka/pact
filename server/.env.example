# Postgres connection string
DATABASE_URL=postgresql://user:password@localhost:5432/pact

# Secret used to sign/verify JWTs — generate a long random value, e.g. `openssl rand -base64 32`
JWT_SECRET=

# Origin of the deployed client app, used for CORS (both REST and Socket.io)
# Local dev: http://localhost:3000
CLIENT_ORIGIN=
